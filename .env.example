# Run `supabase start` to get these values
VITE_SUPABASE_URL=local-supabase-url
VITE_SUPABASE_ANON_KEY=local-supabase-anon-key
# VAPID keys for push notifications - generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key
# CORS origins for edge functions (comma-separated)
# CORS_ORIGIN=http://localhost:5173,https://app.freshersco.com
