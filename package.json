{
	"name": "cleaner-hire-pwa",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"engines": {
		"node": "24.x"
	},
	"overrides": {
		"vite-plugin-pwa": {
			"vite": "^7.0.0",
			"@vite-pwa/assets-generator": "^1.0.2"
		},
		"serialize-javascript": "7.0.3"
	},
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"check": "biome check",
		"check:fix": "biome check --write",
		"test": "vitest",
		"test:unit": "vitest unit",
		"test:int": "vitest integration",
		"test:e2e": "playwright test",
		"type-check": "tsc --noEmit",
		"create-assets": "pwa-assets-generator -p minimal-2023 --html.preset 2023 public/icon-source.svg",
