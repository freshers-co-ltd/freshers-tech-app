{
	"name": "freshers-pwa",
	"private": true,
	"version": "0.9.0",
	"type": "module",
	"engines": {
		"node": "24.x"
	},
	"overrides": {
		"vite-plugin-pwa": {
			"@vite-pwa/assets-generator": "^1.0.2"
		},
		"serialize-javascript": "7.0.3"
	},
	"scripts": {
		"dev": "vite",
		"prebuild": "node scripts/extract-privacy-notice.mjs",
		"build": "tsc -p tsconfig.app.json && vite build",
		"preview": "vite preview",
		"check": "biome check",
		"check:fix": "biome check --write",
		"test": "vitest",
		"test:unit": "vitest unit",
		"test:int": "vitest integration",
		"test:e2e": "playwright test",
		"type-check": "tsc -p tsconfig.app.json --noEmit",
		"create-assets": "pwa-assets-generator -p minimal-2023 --html.preset 2023 public/icon-source.svg",
		"update-types": "npx supabase gen types typescript --local --schema public,storage > src/lib/database.types.ts"
	},
	"dependencies": {
		"@hookform/resolvers": "5.2.2",
		"@supabase/supabase-js": "^2.110.0",
		"@tailwindcss/vite": "4.2.0",
		"@tanstack/react-table": "8.21.3",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"date-fns": "4.1.0",
		"input-otp": "1.4.2",
		"lucide-react": "0.575.0",
		"media-chrome": "4.19.0",
		"nuqs": "2.8.9",
		"radix-ui": "1.4.3",
		"react": "19.2.0",
		"react-day-picker": "9.14.0",
		"react-dom": "19.2.0",
		"react-dropzone": "15.0.0",
		"react-hook-form": "7.71.2",
		"react-router-dom": "7.18.0",
		"recharts": "3.8.0",
		"sonner": "2.0.7",
		"tailwind-merge": "3.5.0",
		"vaul": "1.1.2",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.2",
		"@playwright/test": "1.58.2",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@testing-library/user-event": "14.6.1",
		"@types/node": "24.10.13",
		"@types/react": "19.2.5",
		"@types/react-dom": "19.2.3",
		"@vite-pwa/assets-generator": "1.0.2",
		"@vitejs/plugin-react": "5.1.4",
		"globals": "16.5.0",
		"jsdom": "27.4.0",
		"msw": "2.12.10",
		"pdf-parse": "2.4.5",
		"shadcn": "3.8.5",
		"tailwindcss": "4.2.0",
		"tw-animate-css": "1.4.0",
		"typescript": "5.9.3",
		"vite": "7.3.6",
		"vite-plugin-pwa": "1.3.0",
		"vitest": "4.1.9",
		"workbox-core": "7.4.1",
		"workbox-precaching": "7.4.1"
	}
}
